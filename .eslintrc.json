{
  "root": true,
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "lib/**",
    "*.js",
    "*.d.ts",
    "**/*.d.ts",
    ".nx/**",
    "coverage/**",
    "**/index.d.ts"
  ],
  "plugins": ["@nx", "@typescript-eslint"],
  "extends": ["plugin:@typescript-eslint/recommended"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "extends": ["plugin:@typescript-eslint/recommended", "prettier"],
      "rules": {
        "@nx/enforce-module-boundaries": [
          "error",
          {
            "enforceBuildableLibDependency": true,
            "allow": [],
            "depConstraints": [
              {
                "sourceTag": "scope:domain-primitives",
                "onlyDependOnLibsWithTags": ["scope:utils", "scope:domain-primitives"]
              },
              {
                "sourceTag": "scope:value-objects",
                "onlyDependOnLibsWithTags": [
                  "scope:utils",
                  "scope:contracts",
                  "scope:domain-primitives",
                  "scope:value-objects"
                ]
              },
              {
                "sourceTag": "scope:repositories",
                "onlyDependOnLibsWithTags": [
                  "scope:utils",
                  "scope:domain-primitives",
                  "scope:value-objects",
                  "scope:contracts",
                  "scope:testing",
                  "scope:logging",
                  "scope:repositories"
                ]
              },
              {
                "sourceTag": "scope:nestjs",
                "onlyDependOnLibsWithTags": [
                  "scope:di",
                  "scope:utils",
                  "scope:events",
                  "scope:resilience",
                  "scope:process-managers",
                  "scope:cqrs",
                  "scope:acl",
                  "scope:core",
                  "scope:policies",
                  "scope:messaging",
                  "scope:validation",
                  "scope:contracts",
                  "scope:logging",
                  "scope:testing"
                ]
              },
              {
                "sourceTag": "scope:aggregates",
                "onlyDependOnLibsWithTags": [
                  "scope:utils",
                  "scope:domain-primitives",
                  "scope:value-objects",
                  "scope:contracts",
                  "scope:logging",
                  "scope:aggregates"
                ]
              },
              {
                "sourceTag": "scope:core",
                "onlyDependOnLibsWithTags": [
                  "scope:core",
                  "scope:contracts",
                  "scope:value-objects",
                  "scope:aggregates"
                ]
              },
              {
                "sourceTag": "scope:utils",
                "onlyDependOnLibsWithTags": ["scope:utils", "scope:contracts"]
              },
              {
                "sourceTag": "scope:validation",
                "onlyDependOnLibsWithTags": [
                  "scope:utils",
                  "scope:domain-primitives",
                  "scope:validation",
                  "scope:contracts"
                ]
              },
              {
                "sourceTag": "scope:policies",
                "onlyDependOnLibsWithTags": [
                  "scope:contracts",
                  "scope:validation",
                  "scope:utils",
                  "scope:logging",
                  "scope:policies"
                ]
              },
              {
                "sourceTag": "scope:events",
                "onlyDependOnLibsWithTags": [
                  "scope:domain-primitives",
                  "scope:value-objects",
                  "scope:aggregates",
                  "scope:utils",
                  "scope:events",
                  "scope:contracts",
                  "scope:di",
                  "scope:logging"
                ]
              },
              {
                "sourceTag": "scope:cqrs",
                "onlyDependOnLibsWithTags": [
                  "scope:core",
                  "scope:domain-primitives",
                  "scope:events",
                  "scope:validation",
                  "scope:utils",
                  "scope:contracts",
                  "scope:resilience",
                  "scope:di",
                  "scope:logging",
                  "scope:cqrs"
                ]
              },
              {
                "sourceTag": "scope:acl",
                "onlyDependOnLibsWithTags": [
                  "scope:core",
                  "scope:domain-primitives",
                  "scope:events",
                  "scope:utils",
                  "scope:acl",
                  "scope:testing",
                  "scope:logging",
                  "scope:contracts",
                  "scope:validation"
                ]
              },
              {
                "sourceTag": "scope:process-managers",
                "onlyDependOnLibsWithTags": [
                  "scope:core",
                  "scope:domain-primitives",
                  "scope:events",
                  "scope:utils",
                  "scope:contracts",
                  "scope:testing",
                  "scope:logging"
                ]
              },
              {
                "sourceTag": "scope:projections",
                "onlyDependOnLibsWithTags": [
                  "scope:core",
                  "scope:domain-primitives",
                  "scope:events",
                  "scope:contracts",
                  "scope:utils",
                  "scope:projections",
                  "scope:logging"
                ]
              },
              {
                "sourceTag": "scope:messaging",
                "onlyDependOnLibsWithTags": [
                  "scope:contracts",
                  "scope:utils",
                  "scope:di",
                  "scope:messaging",
                  "scope:domain-primitives",
                  "scope:logging"
                ]
              },
              {
                "sourceTag": "scope:resilience",
                "onlyDependOnLibsWithTags": [
                  "scope:core",
                  "scope:domain-primitives",
                  "scope:utils",
                  "scope:resilience",
                  "scope:contracts",
                  "scope:logging"
                ]
              },
              {
                "sourceTag": "scope:testing",
                "onlyDependOnLibsWithTags": [
                  "scope:domain-primitives",
                  "scope:contracts",
                  "scope:utils",
                  "scope:messaging",
                  "scope:events",
                  "scope:testing"
                ]
              },
              {
                "sourceTag": "scope:enterprise",
                "onlyDependOnLibsWithTags": ["scope:*", "scope:enterprise", "*"]
              },
              {
                "sourceTag": "scope:cli",
                "onlyDependOnLibsWithTags": [
                  "scope:core",
                  "scope:domain-primitives",
                  "scope:aggregates",
                  "scope:value-objects",
                  "scope:utils",
                  "scope:contracts",
                  "scope:cli",
                  "scope:logging"
                ]
              },
              {
                "sourceTag": "scope:contracts",
                "onlyDependOnLibsWithTags": ["scope:contracts", "scope:utils"]
              },
              {
                "sourceTag": "scope:domain-services",
                "onlyDependOnLibsWithTags": [
                  "scope:contracts",
                  "scope:core",
                  "scope:domain-primitives",
                  "scope:aggregates",
                  "scope:repositories",
                  "scope:events",
                  "scope:validation",
                  "scope:utils",
                  "scope:di",
                  "scope:logging",
                  "scope:domain-services"
                ]
              },
              {
                "sourceTag": "scope:logging",
                "onlyDependOnLibsWithTags": [
                  "scope:domain-primitives",
                  "scope:utils",
                  "scope:contracts",
                  "scope:logging"
                ]
              },
              {
                "sourceTag": "scope:di",
                "onlyDependOnLibsWithTags": [
                  "scope:core",
                  "scope:domain-primitives",
                  "scope:utils",
                  "scope:contracts",
                  "scope:logging",
                  "scope:di"
                ]
              },
              {
                "sourceTag": "scope:event-store",
                "onlyDependOnLibsWithTags": [
                  "scope:contracts",
                  "scope:core",
                  "scope:events",
                  "scope:logging",
                  "scope:utils",
                  "scope:event-store"
                ]
              },
              {
                "sourceTag": "scope:event-scheduling",
                "onlyDependOnLibsWithTags": [
                  "scope:contracts",
                  "scope:testing",
                  "scope:events",
                  "scope:utils"
                ]
              },
              {
                "sourceTag": "scope:examples",
                "onlyDependOnLibsWithTags": ["*"]
              }
            ]
          }
        ],
        "@typescript-eslint/no-unused-vars": [
          "warn",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_",
            "caughtErrorsIgnorePattern": "^_"
          }
        ],
        "@typescript-eslint/explicit-function-return-type": "error",
        "@typescript-eslint/no-explicit-any": "warn",
        "@typescript-eslint/prefer-readonly": "off",
        "@typescript-eslint/prefer-nullish-coalescing": "off",
        "@typescript-eslint/prefer-optional-chain": "off",
        "@typescript-eslint/consistent-type-definitions": ["error", "interface"],
        "@typescript-eslint/consistent-type-imports": [
          "error",
          {
            "prefer": "type-imports",
            "disallowTypeAnnotations": false
          }
        ],
        "prefer-const": "error",
        "no-var": "error",
        "object-shorthand": "error",
        "prefer-template": "error"
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "extends": ["plugin:@nx/typescript"],
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["plugin:@nx/javascript"],
      "rules": {}
    },
    {
      "files": ["*.test.ts", "*.test.tsx"],
      "env": {
        "jest": true
      },
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/explicit-function-return-type": "off",
        "@typescript-eslint/no-non-null-assertion": "off"
      }
    }
  ]
}
