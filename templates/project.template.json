{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vytches-ddd/{PACKAGE_NAME}",
  "projectType": "library",
  "sourceRoot": "packages/{PACKAGE_NAME}/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build",
        "cwd": "packages/{PACKAGE_NAME}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run packages/{PACKAGE_NAME}/tests --reporter=verbose"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/{PACKAGE_NAME}/**/*.ts"]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project packages/{PACKAGE_NAME}/tsconfig.json"
      }
    }
  },
  "tags": ["type:lib", "scope:{PACKAGE_NAME}", "layer:{LAYER_TAG}"]
}
