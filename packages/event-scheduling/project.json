{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vytches-ddd/event-scheduling",
  "projectType": "library",
  "sourceRoot": "packages/event-scheduling/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build",
        "cwd": "packages/event-scheduling"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run packages/event-scheduling/tests --reporter=verbose"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/event-scheduling/**/*.ts"]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project packages/event-scheduling/tsconfig.json"
      }
    }
  },
  "tags": ["type:lib", "scope:event-scheduling", "layer:infrastructure"]
}
