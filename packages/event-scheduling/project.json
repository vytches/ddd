{
  "name": "@vytches-ddd/event-scheduling",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/event-scheduling/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:event-scheduling"],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/event-scheduling"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/event-scheduling/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "coverage/packages/event-scheduling"
      }
    }
  }
}
