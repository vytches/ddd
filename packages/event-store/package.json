{
  "name": "@vytches-ddd/event-store",
  "version": "0.0.1",
  "description": "Enterprise-grade Event Store with Event Sourcing support for Domain-Driven Design applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "keywords": [
    "ddd",
    "domain-driven-design",
    "event-store",
    "event-sourcing",
    "cqrs",
    "typescript"
  ],
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@vytches-ddd/contracts": "workspace:*",
    "@vytches-ddd/core": "workspace:*",
    "@vytches-ddd/logging": "workspace:*"
  }
}
