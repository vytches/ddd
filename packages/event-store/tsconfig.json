{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "declarationMap": false, // Disable .d.ts.map files for smaller bundles
    "sourceMap": false // Disable source maps for production builds
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "../contracts/src/**/*",
    "../core/src/**/*",
    "../events/src/**/*",
    "../logging/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
