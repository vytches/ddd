{
  "name": "@vytches-ddd/aggregates",
  "projectType": "library",
  "sourceRoot": "packages/aggregates/src",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/aggregates",
        "main": "packages/aggregates/src/index.ts",
        "tsConfig": "packages/aggregates/tsconfig.json",
        "assets": ["packages/aggregates/*.md"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run packages/aggregates/tests --reporter=verbose"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/aggregates/**/*.ts"]
      }
    }
  },
  "tags": ["type:lib", "scope:aggregates"]
}
