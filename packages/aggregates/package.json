{
  "name": "@vytches-ddd/aggregates",
  "version": "1.0.0",
  "description": "Aggregate root implementations and capabilities for VytchesDDD framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./capabilities": {
      "types": "./dist/capabilities/index.d.ts",
      "import": "./dist/capabilities/index.js",
      "require": "./dist/capabilities/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@vytches-ddd/domain-primitives": "workspace:*",
    "@vytches-ddd/utils": "workspace:*",
    "@vytches-ddd/contracts": "workspace:*",
    "@vytches-ddd/logging": "workspace:*"
  },
  "devDependencies": {
    "@vytches-ddd/testing": "workspace:*",
    "typescript": "^5.0.0",
    "vite": "^4.0.0",
    "vitest": "^0.34.0"
  },
  "keywords": [
    "ddd",
    "domain-driven-design",
    "aggregate",
    "aggregate-root",
    "event-sourcing",
    "capabilities",
    "typescript"
  ],
  "author": "VytchesDDD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vytches/vytches-ddd.git",
    "directory": "packages/aggregates"
  },
  "nx": {
    "tags": [
      "scope:aggregates",
      "type:lib"
    ]
  }
}
