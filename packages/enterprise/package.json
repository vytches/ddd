{
  "name": "@vytches/ddd",
  "version": "0.29.2",
  "description": "Complete Domain-Driven Design framework for TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./llm-context": "./llm-context.md",
    "./llm-context.md": "./llm-context.md"
  },
  "sideEffects": false,
  "bin": {
    "ddd": "./bin/init-context.mjs",
    "vytches-ddd": "./bin/init-context.mjs"
  },
  "files": [
    "LLMGUIDE.md",
    "README.md",
    "bin",
    "dist",
    "llm-context.md"
  ],
  "keywords": [
    "ddd",
    "domain-driven-design",
    "typescript",
    "enterprise"
  ],
  "author": "VytchesDDD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vytches/ddd.git",
    "directory": "packages/enterprise"
  },
  "scripts": {
    "prebuild": "cp ../../docs/llm-context.md ./llm-context.md",
    "prepack": "cp ../../docs/llm-context.md ./llm-context.md",
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "nx": {
    "tags": [
      "scope:enterprise",
      "type:lib",
      "layer:infrastructure"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@vytches/ddd-acl": "workspace:*",
    "@vytches/ddd-aggregates": "workspace:*",
    "@vytches/ddd-contracts": "workspace:*",
    "@vytches/ddd-cqrs": "workspace:*",
    "@vytches/ddd-di": "workspace:*",
    "@vytches/ddd-domain-primitives": "workspace:*",
    "@vytches/ddd-domain-services": "workspace:*",
    "@vytches/ddd-events": "workspace:*",
    "@vytches/ddd-logging": "workspace:*",
    "@vytches/ddd-messaging": "workspace:*",
    "@vytches/ddd-policies": "workspace:*",
    "@vytches/ddd-projections": "workspace:*",
    "@vytches/ddd-repositories": "workspace:*",
    "@vytches/ddd-resilience": "workspace:*",
    "@vytches/ddd-utils": "workspace:*",
    "@vytches/ddd-validation": "workspace:*",
    "@vytches/ddd-value-objects": "workspace:*"
  }
}
