{
  "name": "@vytches-ddd/enterprise",
  "version": "0.1.0",
  "description": "All-in-one enterprise bundle",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "nx": {
    "tags": [
      "scope:enterprise",
      "type:lib"
    ]
  },
  "dependencies": {
    "@vytches-ddd/core": "workspace:*",
    "@vytches-ddd/utils": "workspace:*",
    "@vytches-ddd/validation": "workspace:*",
    "@vytches-ddd/policies": "workspace:*",
    "@vytches-ddd/events": "workspace:*",
    "@vytches-ddd/cqrs": "workspace:*",
    "@vytches-ddd/acl": "workspace:*",
    "@vytches-ddd/projections": "workspace:*",
    "@vytches-ddd/messaging": "workspace:*",
    "@vytches-ddd/resilience": "workspace:*",
    "@vytches-ddd/di": "workspace:*"
  }
}
