{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "declarationMap": false, // Disable .d.ts.map files for smaller bundles
    "sourceMap": false // Disable source maps for production builds
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "../contracts/src/**/*",
    "../domain-primitives/src/**/*",
    "../events/src/**/*",
    "../aggregates/src/**/*",
    "../value-objects/src/**/*",
    "../utils/src/**/*",
    "../logging/src/**/*",
    "../core/src/**/*",
    "../repositories/src/**/*",
    "../testing/src/**/*",
    "../validation/src/**/*",
    "../acl/src/**/*",
    "../messaging/src/**/*",
    "../policies/src/**/*",
    "../resilience/src/**/*",
    "../projections/src/**/*",
    "../cqrs/src/**/*",
    "../di/src/**/*",
    "../domain-services/src/**/*",
    "../cli/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
