{
  "name": "@vytches-ddd/value-objects",
  "projectType": "library",
  "sourceRoot": "packages/value-objects/src",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/value-objects",
        "main": "packages/value-objects/src/index.ts",
        "tsConfig": "packages/value-objects/tsconfig.json",
        "assets": ["packages/value-objects/*.md"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run packages/value-objects/tests --reporter=verbose"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/value-objects/**/*.ts"]
      }
    }
  },
  "tags": ["type:lib", "scope:value-objects"]
}
