{
  "name": "@vytches/ddd-domain-primitives",
  "version": "0.29.2",
  "description": "Core domain primitives and foundational types for Domain-Driven Design",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "LLMGUIDE.md",
    "README.md",
    "dist"
  ],
  "keywords": [
    "ddd",
    "domain-driven-design",
    "typescript",
    "domain, primitives"
  ],
  "author": "VytchesDDD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vytches/ddd.git",
    "directory": "packages/domain-primitives"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vytches/ddd-contracts": "workspace:*",
    "@vytches/ddd-utils": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "nx": {
    "tags": [
      "scope:domain-primitives",
      "type:lib",
      "layer:foundation"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
