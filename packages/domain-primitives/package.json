{
  "name": "@vytches-ddd/domain-primitives",
  "version": "0.1.0",
  "description": "Core domain primitives and foundational types for Domain-Driven Design",
  "keywords": [
    "ddd",
    "domain-driven-design",
    "primitives",
    "errors",
    "actor",
    "typescript"
  ],
  "author": "Vytches DDD",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./actor": {
      "types": "./dist/actor/index.d.ts",
      "import": "./dist/actor/index.js",
      "require": "./dist/actor/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@vytches-ddd/utils": "*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^2.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
