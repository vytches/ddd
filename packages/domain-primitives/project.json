{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vytches-ddd/domain-primitives",
  "projectType": "library",
  "sourceRoot": "packages/domain-primitives/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build",
        "cwd": "packages/domain-primitives"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run packages/domain-primitives/tests --reporter=verbose"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/domain-primitives/**/*.ts"]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project packages/domain-primitives/tsconfig.json"
      }
    }
  },
  "tags": ["type:lib", "scope:domain-primitives", "layer:foundation"]
}
