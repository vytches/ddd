{
  "name": "@vytches-ddd/domain-primitives",
  "projectType": "library",
  "sourceRoot": "packages/domain-primitives/src",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/domain-primitives",
        "main": "packages/domain-primitives/src/index.ts",
        "tsConfig": "packages/domain-primitives/tsconfig.json",
        "assets": ["packages/domain-primitives/*.md"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/packages/domain-primitives"],
      "options": {
        "jestConfig": "packages/domain-primitives/jest.config.js",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/domain-primitives/**/*.ts"]
      }
    }
  },
  "tags": ["type:lib", "scope:domain-primitives"]
}
