{
  "name": "@vytches-ddd/repositories",
  "version": "0.1.0",
  "description": "Domain-Driven Design repository patterns and base implementations",
  "keywords": [
    "ddd",
    "domain-driven-design",
    "repository",
    "unit-of-work",
    "aggregate-repository",
    "typescript"
  ],
  "author": "Vytches DDD",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@vytches-ddd/domain-primitives": "*",
    "@vytches-ddd/value-objects": "*",
    "@vytches-ddd/utils": "*",
    "@vytches-ddd/contracts": "*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^2.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}