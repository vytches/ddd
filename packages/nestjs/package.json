{
  "name": "@vytches/ddd-nestjs",
  "version": "1.1.0",
  "description": "NestJS adapter for VytchesDDD - Enterprise Domain-Driven Design framework integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ddd",
    "domain-driven-design",
    "nestjs",
    "adapter",
    "dependency-injection",
    "enterprise",
    "typescript",
    "cqrs",
    "event-sourcing"
  ],
  "author": "VytchesDDD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vytches/ddd.git",
    "directory": "packages/nestjs"
  },
  "dependencies": {
    "@vytches/ddd-di": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@vytches/ddd-core": "workspace:*",
    "@vytches/ddd-cqrs": "workspace:*",
    "@vytches/ddd-events": "workspace:*",
    "@vytches/ddd-process-managers": "workspace:*",
    "@vytches/ddd-utils": "workspace:*",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": false
    },
    "@nestjs/core": {
      "optional": false
    },
    "@vytches/ddd-core": {
      "optional": true
    },
    "@vytches/ddd-cqrs": {
      "optional": true
    },
    "@vytches/ddd-events": {
      "optional": true
    },
    "@vytches/ddd-process-managers": {
      "optional": true
    },
    "@vytches/ddd-utils": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/node": "^20.10.4",
    "@vytches/ddd-core": "workspace:*",
    "@vytches/ddd-cqrs": "workspace:*",
    "@vytches/ddd-events": "workspace:*",
    "@vytches/ddd-process-managers": "workspace:*",
    "@vytches/ddd-testing": "workspace:*",
    "@vytches/ddd-utils": "workspace:*",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.1.0"
  },
  "nx": {
    "tags": [
      "scope:nestjs",
      "type:adapter",
      "layer:integration"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
