{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vytches/ddd-nestjs",
  "sourceRoot": "packages/nestjs/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build",
        "cwd": "packages/nestjs"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run packages/nestjs/tests --reporter=verbose"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/nestjs/**/*.ts"]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project packages/nestjs/tsconfig.json"
      }
    }
  },
  "tags": ["type:lib", "scope:enterprise", "layer:integration", "framework:nestjs"]
}
