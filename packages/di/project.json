{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vytches/ddd-di",
  "projectType": "library",
  "sourceRoot": "packages/di/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build",
        "cwd": "packages/di"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run packages/di/tests --reporter=verbose"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/di/**/*.ts"]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project packages/di/tsconfig.json"
      }
    }
  },
  "tags": ["type:lib", "scope:di", "layer:foundation"]
}
