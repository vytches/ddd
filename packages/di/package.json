{
  "name": "@vytches-ddd/di",
  "version": "1.0.0",
  "description": "Global Service Locator with Optional Context Isolation for Dependency Injection",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 20",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vytches-ddd/domain-primitives": "workspace:*",
    "@vytches-ddd/logging": "workspace:*",
    "@vytches-ddd/utils": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "keywords": [
    "ddd",
    "domain-driven-design",
    "dependency-injection",
    "service-locator",
    "ioc",
    "container"
  ],
  "author": "VytchesDDD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vytches/ddd.git",
    "directory": "packages/di"
  },
  "bugs": {
    "url": "https://github.com/vytches/ddd/issues"
  },
  "homepage": "https://github.com/vytches/ddd#readme"
}
