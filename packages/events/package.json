{
  "name": "@vytches/ddd-events",
  "version": "0.22.0",
  "description": "Unified event system with context-aware routing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ddd",
    "domain-driven-design",
    "typescript",
    "events"
  ],
  "author": "VytchesDDD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vytches/ddd.git",
    "directory": "packages/events"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vytches/ddd-aggregates": "0.22.0",
    "@vytches/ddd-contracts": "0.24.0",
    "@vytches/ddd-domain-primitives": "0.22.0",
    "@vytches/ddd-value-objects": "0.22.0"
  },
  "devDependencies": {
    "@vytches/ddd-testing": "0.22.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "nx": {
    "tags": [
      "scope:events",
      "type:lib",
      "layer:architecture"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "gitHead": "0fe40bf9b21af2582cc0768e08274edf5d93aba5"
}
