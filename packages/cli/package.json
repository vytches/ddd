{
  "name": "@vytches-ddd/cli",
  "version": "0.2.0",
  "description": "Code generation tools and CLI framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "bin": {
    "vytches-ddd": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ddd",
    "domain-driven-design",
    "typescript",
    "cli"
  ],
  "author": "VytchesDDD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vytches/vytches-ddd.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "handlebars": "^4.7.8"
  },
  "peerDependencies": {
    "@vytches-ddd/core": "workspace:*"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@vytches-ddd/testing": "workspace:*",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "nx": {
    "tags": [
      "scope:cli",
      "type:lib",
      "layer:tooling"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
