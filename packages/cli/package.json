{
  "name": "@vytches-ddd/cli",
  "version": "0.1.0",
  "description": "Code generation and development tools",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vytches-ddd": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vytches-ddd/core": "workspace:*",
    "@vytches-ddd/utils": "workspace:*",
    "@vytches-ddd/logging": "workspace:*"
  },
  "nx": {
    "tags": [
      "scope:cli",
      "type:tool"
    ]
  }
}
