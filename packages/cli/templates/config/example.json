{
  "example": {
    "aggregate": {
      "name": "User",
      "domain": "Authentication",
      "description": "User aggregate representing system users",
      "properties": [
        {
          "name": "email",
          "type": "string"
        },
        {
          "name": "isActive",
          "type": "boolean"
        }
      ],
      "validations": [
        "if (!email || typeof email !== 'string') throw new ValidationError('Email is required');"
      ],
      "events": true,
      "eventName": "UserCreated",
      "eventFileName": "user-created",
      "eventProperties": [
        {
          "name": "email",
          "value": "email"
        }
      ],
      "methods": [
        {
          "name": "activate",
          "description": "Activate the user",
          "parameters": [],
          "returnType": "void",
          "validations": [],
          "raisesEvent": true,
          "eventName": "UserActivated",
          "eventProperties": [
            {
              "name": "userId",
              "value": "this.id.value"
            }
          ],
          "body": "this._isActive = true;"
        }
      ]
    },
    "entity": {
      "name": "Profile",
      "domain": "Authentication",
      "description": "User profile entity",
      "properties": [
        {
          "name": "firstName",
          "type": "string"
        },
        {
          "name": "lastName",
          "type": "string"
        }
      ],
      "validations": [
        "if (!firstName) throw new ValidationError('First name is required');"
      ]
    },
    "valueObject": {
      "name": "Email",
      "domain": "Authentication",
      "description": "Email value object with validation",
      "properties": [
        {
          "name": "value",
          "type": "string"
        }
      ],
      "validations": [
        "if (!value || !value.includes('@')) throw new ValidationError('Invalid email format');"
      ],
      "stringMethod": "return this.props.value;"
    },
    "domainService": {
      "name": "UserRegistrationService",
      "domain": "Authentication",
      "description": "Service for user registration business logic",
      "serviceId": "userRegistration",
      "dependencies": [
        {
          "name": "userRepository",
          "type": "IUserRepository"
        }
      ],
      "methods": [
        {
          "name": "registerUser",
          "description": "Register a new user",
          "parameters": [
            {
              "name": "email",
              "type": "string"
            },
            {
              "name": "password",
              "type": "string"
            }
          ],
          "returnType": "User",
          "validations": [
            "if (!email) throw new ValidationError('Email is required');"
          ],
          "body": "const user = User.create(email, password); await this.userRepository.save(user); const result = user;"
        }
      ]
    }
  }
}