}

/**
 * Policy violation error for {{name}}
 */
export class {{name}}PolicyViolationError extends Error {
  constructor(public readonly violations: Array<{
    code: string;
    message: string;
    severity: string;
    field?: string;
  }>) {
    super(`{{name}} policy violations: ${violations.map(v => v.message).join(', ')}`);
    this.name = '{{name}}PolicyViolationError';
  }

  /**
   * Get violations by severity
   */
  getViolationsBySeverity(severity: string): Array<{
    code: string;
    message: string;
    severity: string;
    field?: string;
  }> {
    return this.violations.filter(v => v.severity === severity);
  }

  /**
   * Check if there are critical violations
   */
  hasCriticalViolations(): boolean {
    return this.violations.some(v => v.severity === 'ERROR');
  }
}

