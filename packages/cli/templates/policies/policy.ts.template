export class {{name}}Policy {
  private static readonly POLICY_ID = '{{policyId}}';
  private static readonly DOMAIN = '{{domain}}';

  /**
   * Create {{name}} policy with business rules
   */
  static create(): PolicyBuilder<{{entityType}}> {
    return PolicyBuilder.create<{{entityType}}>()
      .withId(this.POLICY_ID)
      .withDomain(this.DOMAIN)
      .withName('{{displayName}}')
      {{#each rules}}
      {{#if isAsync}}
      .mustAsync(new {{specificationName}}())
      {{else}}
      .must(new {{specificationName}}())
      {{/if}}
      .withCode('{{errorCode}}')
      .withMessage('{{errorMessage}}')
      .withSeverity('{{severity}}')
      {{#unless @last}}.and(){{/unless}}
      {{/each}};
  }

  /**
   * Create conditional policy with business context
   */
  static createConditional(): PolicyBuilder<{{entityType}}> {
    return this.create()
      {{#each conditionalRules}}
      .when({{condition}})
      .then()
      {{#if isAsync}}
      .mustAsync(new {{specificationName}}())
      {{else}}
      .must(new {{specificationName}}())
      {{/if}}
      .withCode('{{errorCode}}')
      .withMessage('{{errorMessage}}')
      {{#if otherwise}}
      .otherwise()
      .should(new {{otherwiseSpecification}}())
      .withSeverity('WARNING')
      {{/if}}
      {{/each}};
  }

  /**
   * Validate entity against policy
   */
  static async validate(
    entity: {{entityType}},
    context: PolicyContext
  ): Promise<Result<{{entityType}}, Error>> {
    const policy = this.create().build();
    
    const result = await policy.check({ entity, context });
    
    if (result.isFailure()) {
      return Result.failure(new {{name}}PolicyViolationError(result.error.violations));
    }
    
    return Result.success(entity);
  }

  /**
   * Check if entity satisfies policy rules
   */
  static async check(
    entity: {{entityType}},
    context?: Partial<PolicyContext>
  ): Promise<boolean> {
    const policyContext = PolicyContext.create()
      .withUserId(context?.userId || 'system')
      .withRequestId(context?.requestId || 'default')
      .build();

    const result = await this.validate(entity, policyContext);
    return result.isSuccess();
  }

  {{#if customMethods}}
