{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "symlinkDirectories": ["node_modules"]
  },
  "autoMode": {
    "environment": [
      "Shared TypeScript npm library (Nx monorepo with multiple packages).",
      "All public API changes must maintain backward compatibility.",
      "Every exported class/function must have corresponding unit tests.",
      "Dual ESM/CJS build output, tree-shaking support required."
    ],
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(pnpm test *)",
      "Bash(pnpm run lint *)",
      "Bash(pnpm tsc --noEmit *)",
      "Bash(pnpm nx *)",
      "Bash(pnpm vitest *)"
    ],
    "soft_deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(pnpm publish *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-edit-format.js\""
          }
        ],
        "description": "Auto-format after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-edit-typecheck.js\""
          }
        ],
        "description": "TypeScript check after editing .ts files"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/pm-task-check.js\""
          }
        ],
        "description": "PM health check when task files change"
      }
    ]
  }
}
