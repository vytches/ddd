{
  "name": "@vytches/ddd",
  "version": "0.6.0",
  "description": "Complete Domain-Driven Design framework for TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ddd",
    "domain-driven-design",
    "typescript",
    "enterprise"
  ],
  "author": "VytchesDDD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vytches/ddd.git",
    "directory": "packages/enterprise"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "nx": {
    "tags": [
      "scope:enterprise",
      "type:lib",
      "layer:infrastructure"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "dependencies": {
    "@vytches/ddd-acl": "0.5.0",
    "@vytches/ddd-aggregates": "0.5.0",
    "@vytches/ddd-contracts": "0.7.0",
    "@vytches/ddd-core": "0.5.0",
    "@vytches/ddd-cqrs": "0.5.0",
    "@vytches/ddd-di": "0.5.0",
    "@vytches/ddd-domain-primitives": "0.5.0",
    "@vytches/ddd-domain-services": "0.5.0",
    "@vytches/ddd-event-scheduling": "0.5.0",
    "@vytches/ddd-event-store": "0.5.0",
    "@vytches/ddd-events": "0.5.0",
    "@vytches/ddd-logging": "0.5.0",
    "@vytches/ddd-messaging": "0.5.0",
    "@vytches/ddd-policies": "0.6.0",
    "@vytches/ddd-projections": "0.5.0",
    "@vytches/ddd-repositories": "0.5.0",
    "@vytches/ddd-resilience": "0.5.0",
    "@vytches/ddd-utils": "0.5.0",
    "@vytches/ddd-validation": "0.6.0",
    "@vytches/ddd-value-objects": "0.5.0"
  },
  "gitHead": "444cef496653a739f10f847343ba0629be148547"
}
