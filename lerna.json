{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "independent",
  "npmClient": "pnpm",
  "packages": ["packages/*"],
  "command": {
    "publish": {
      "conventionalCommits": true,
      "message": "chore(release): publish packages",
      "registry": "https://npm.pkg.github.com",
      "distTag": "latest",
      "allowBranch": ["main", "release/*", "develop", "feature/*"],
      "ignoreChanges": [
        "**/*.md",
        "**/*.spec.ts",
        "**/*.test.ts",
        "**/test/**",
        "**/tests/**",
        "**/__tests__/**",
        "**/stories/**",
        "**/*.stories.*"
      ]
    },
    "version": {
      "allowBranch": ["main", "release/*", "develop", "feature/*"],
      "conventionalCommits": true,
      "exact": true,
      "push": false,
      "createRelease": "github",
      "tagVersionPrefix": "v",
      "message": "chore(release): version packages",
      "ignoreChanges": [
        "**/*.md",
        "**/*.spec.ts",
        "**/*.test.ts",
        "**/test/**",
        "**/tests/**",
        "**/__tests__/**",
        "**/stories/**",
        "**/*.stories.*"
      ]
    }
  },
  "changelogPreset": {
    "name": "conventionalcommits",
    "types": [
      {
        "type": "feat",
        "section": "✨ Features"
      },
      {
        "type": "fix",
        "section": "🐛 Bug Fixes"
      },
      {
        "type": "docs",
        "section": "📚 Documentation"
      },
      {
        "type": "style",
        "section": "💎 Styles"
      },
      {
        "type": "refactor",
        "section": "📦 Refactor"
      },
      {
        "type": "perf",
        "section": "🚀 Performance"
      },
      {
        "type": "test",
        "section": "🚨 Tests"
      },
      {
        "type": "build",
        "section": "🛠 Build System"
      },
      {
        "type": "ci",
        "section": "⚙️ CI/CD"
      },
      {
        "type": "chore",
        "hidden": true
      }
    ]
  }
}
