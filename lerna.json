{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "independent",
  "npmClient": "pnpm",
  "packages": ["packages/*"],
  "command": {
    "publish": {
      "registry": "https://npm.pkg.github.com",
      "conventionalCommits": true,
      "message": "chore: publish releases",
      "allowBranch": ["main", "master", "release/*"],
      "ignoreChanges": ["**/*.md", "**/*.test.ts", "**/*.spec.ts", "**/tests/**"]
    },
    "version": {
      "conventionalCommits": true,
      "changelogPreset": "angular",
      "createRelease": false,
      "exact": true,
      "allowBranch": ["main", "master", "release/*"]
    }
  },
  "changelogPreset": "angular",
  "ignoreChanges": ["**/__tests__/**", "**/*.md"]
}
